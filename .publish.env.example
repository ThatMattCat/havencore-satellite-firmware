# Copy to .publish.env (gitignored) and fill in. Sourced by
# scripts/publish_firmware.sh — runs automatically after every idf.py
# build, scping the freshly built satellite.bin to the HavenCore web
# server so Settings -> Update Firmware can pull it.
#
# Leave HC_PUBLISH_DEST unset (or delete .publish.env) to disable.

# user@host:/absolute/path/to/satellite.bin
HC_PUBLISH_DEST=user@havencore.local:/var/www/havencore/firmware/satellite.bin

# Optional. Path to the SSH private key authorized on the destination.
# If unset, scp uses the default ssh-agent / ~/.ssh/id_* lookup.
#HC_PUBLISH_KEY=~/.ssh/havencore_id_ed25519
